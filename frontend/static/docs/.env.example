# =============================================================================
# VSocial - Environment Configuration Example
# Copy this file to .env and fill in your values
# =============================================================================

# ------------------------------------------------------------------------
# Core Application
# ------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ------------------------------------------------------------------------
# Database (libSQL / SQLite)
# ------------------------------------------------------------------------
# SQLite file path relative to the project root or absolute path
DB_PATH=./database.sqlite

# libSQL remote URL (leave empty for local SQLite)
# LIBSQL_URL=
# LIBSQL_AUTH_TOKEN=

# ------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------
# IMPORTANT: Generate a strong random secret for production!
# Use: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS_OR_MORE
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------------------
# File Uploads
# ------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ------------------------------------------------------------------------
# Email (SMTP)
# ------------------------------------------------------------------------
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vsocial.app

# ------------------------------------------------------------------------
# OAuth (Optional)
# ------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# ------------------------------------------------------------------------
# Web Push Notifications (Optional)
# ------------------------------------------------------------------------
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:noreply@vsocial.app

# ------------------------------------------------------------------------
# Integrations
# ------------------------------------------------------------------------
# TENOR_API_KEY=

# ------------------------------------------------------------------------
# Demo / Maintenance
# ------------------------------------------------------------------------
INSTALL_LOCK=false
# DEMO_MODE=false
# MAINTENANCE_MODE=false
